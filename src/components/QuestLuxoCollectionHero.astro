---
interface Stat {
  label: string;
  value: string | number;
}

interface Props {
  eyebrow: string;
  title: string;
  description: string;
  stats?: Stat[];
}

const { eyebrow, title, description, stats = [] } = Astro.props;
---

<section class="hero">
  <p class="eyebrow">{eyebrow}</p>
  <h1>{title}</h1>
  <p class="description">{description}</p>

  {stats.length > 0 && (
    <div class="hero-stats">
      {stats.map((stat) => (
        <article>
          <strong>{stat.value}</strong>
          <span>{stat.label}</span>
        </article>
      ))}
    </div>
  )}
</section>

<style>
  .hero {
    padding: 120px 30px 80px;
    text-align: center;
    background:
      linear-gradient(rgba(250, 249, 247, 0.94), rgba(250, 249, 247, 0.94)),
      radial-gradient(circle at top, rgba(212, 176, 106, 0.2), transparent 42%);
  }

  .eyebrow {
    color: #d4b06a;
    letter-spacing: 4px;
    font-size: 12px;
    font-weight: 800;
    margin-bottom: 20px;
    text-transform: uppercase;
  }

  h1 {
    color: #173a5e;
    font-size: clamp(48px, 8vw, 76px);
    margin: 0 0 24px;
    line-height: 1;
  }

  .description {
    max-width: 820px;
    margin: auto;
    font-size: 22px;
    line-height: 1.8;
    color: #1f1f1f;
  }

  .hero-stats {
    max-width: 980px;
    margin: 44px auto 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }

  .hero-stats article {
    background: #ffffff;
    border: 1px solid #e8e3d8;
    padding: 22px 16px;
  }

  .hero-stats strong {
    display: block;
    color: #173a5e;
    font-size: 30px;
    margin-bottom: 8px;
  }

  .hero-stats span {
    color: #6d7480;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  @media (max-width: 900px) {
    .hero-stats {
      grid-template-columns: 1fr;
    }

    .description {
      font-size: 18px;
    }
  }
</style>