---
import {
  buildQuestLuxoIntelligence,
} from "../lib/intelligence/questLuxoIntelligence";
import type { QuestLuxoAsset } from "../types/questLuxo";

interface Props {
  asset: QuestLuxoAsset;
  href: string;
}

const { asset, href } = Astro.props as Props;

const configurations = asset.configurations ?? [];
const primaryConfig = configurations[0];

const topNickname = primaryConfig?.nickname ?? asset.reference;
const collectorDemand = asset.intelligence?.collectorDemand ?? 0;
const isPeakDemand = collectorDemand >= 5;
const imageAlt = `${asset.reference} ${asset.model}`;

const intelligenceProfile = asset.intelligence
  ? buildQuestLuxoIntelligence(asset.intelligence)
  : null;

const formatUSD = (value?: number | null) => {
  if (!value) return "Historical MSRP research pending";

  return new Intl.NumberFormat("en-US", {
    style: "currency",
    currency: "USD",
    maximumFractionDigits: 0,
  }).format(value);
};
---

<article class="card">
  <div class="image-card">
    {asset.image ? (
      <img src={asset.image} alt={imageAlt} />
    ) : (
      <span>Image Pending</span>
    )}

    <div class="badges">
      {asset.productionStatus && <span>{asset.productionStatus}</span>}
      {isPeakDemand && <span>Peak Demand</span>}
    </div>

    {intelligenceProfile && (
      <div class="score-badge">
        <strong>{intelligenceProfile.overallScore}</strong>
        <span>{intelligenceProfile.grade}</span>
      </div>
    )}
  </div>

  <p class="model">{asset.brand ?? "Rolex"} {asset.model}</p>

  <h3>Ref. {asset.reference}</h3>

  <p class="nickname">{topNickname}</p>

  {configurations.length > 0 && (
    <div class="nicknames">
      {configurations.map((config) => (
        <span>
          {config.nickname ?? "Configuration"}
          {config.bracelet ? ` · ${config.bracelet}` : ""}
          {config.dial ? ` · ${config.dial}` : ""}
        </span>
      ))}
    </div>
  )}

  <div class="details">
    {asset.material && <p><strong>Material</strong><span>{asset.material}</span></p>}
    {asset.bezel && <p><strong>Bezel</strong><span>{asset.bezel}</span></p>}
    {asset.marketPosition && <p><strong>Market Position</strong><span>{asset.marketPosition}</span></p>}
    {asset.liquidity && <p><strong>Liquidity</strong><span>{asset.liquidity}</span></p>}
    {asset.allocationDifficulty && <p><strong>Allocation</strong><span>{asset.allocationDifficulty}</span></p>}
  </div>

  {intelligenceProfile && (
    <div class="engine">
      <div class="engine-topline">
        <strong>Quest Luxo Score</strong>
        <span>{intelligenceProfile.overallScore}/100</span>
      </div>

      <div class="score-bar">
        <div style={`width: ${intelligenceProfile.overallScore}%`}></div>
      </div>

      <div class="engine-grid">
        <div>
          <strong>{intelligenceProfile.marketStrength}</strong>
          <span>Market</span>
        </div>

        <div>
          <strong>{intelligenceProfile.investmentPotential}</strong>
          <span>Investment</span>
        </div>

        <div>
          <strong>{intelligenceProfile.rarityScore}</strong>
          <span>Rarity</span>
        </div>
      </div>
    </div>
  )}

  {configurations.length > 0 && (
    <div class="msrp">
      <strong>Original MSRP</strong>

      {configurations.map((config) => (
        <p>
          {config.bracelet ?? config.dial ?? config.nickname ?? "Configuration"}:{" "}
          {formatUSD(config.originalMSRP)}
        </p>
      ))}
    </div>
  )}

  {asset.questLuxoView && (
    <div class="view">
      <strong>Quest Luxo View</strong>
      <p>{asset.questLuxoView}</p>
    </div>
  )}

  <a href={href} class="button">
    View Asset Profile
  </a>
</article>

<style>
  .card {
    border: 1px solid #e8e3d8;
    background: #faf9f7;
    padding: 24px;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .image-card {
    position: relative;
    height: 240px;
    background: #ffffff;
    border: 1px solid #eee8dc;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #777;
    margin-bottom: 24px;
    padding: 24px;
    overflow: hidden;
  }

  .image-card img {
    max-width: 100%;
    max-height: 205px;
    object-fit: contain;
  }

  .badges {
    position: absolute;
    top: 14px;
    left: 14px;
    right: 96px;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .badges span {
    background: rgba(23, 58, 94, 0.92);
    color: #ffffff;
    border: 1px solid rgba(212, 176, 106, 0.45);
    padding: 7px 10px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 1.4px;
    text-transform: uppercase;
  }

  .score-badge {
    position: absolute;
    top: 14px;
    right: 14px;
    width: 68px;
    height: 68px;
    background:
      linear-gradient(rgba(23, 58, 94, 0.96), rgba(23, 58, 94, 0.96)),
      radial-gradient(circle at top, rgba(212, 176, 106, 0.35), transparent 55%);
    border: 1px solid rgba(212, 176, 106, 0.5);
    color: #ffffff;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .score-badge strong {
    color: #ffffff;
    font-size: 24px;
    line-height: 1;
  }

  .score-badge span {
    color: #d4b06a;
    font-size: 11px;
    font-weight: 900;
    text-align: center;
    margin-top: 4px;
  }

  .model {
    color: #777;
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin: 0 0 10px;
  }

  h3 {
    color: #173a5e;
    font-size: 30px;
    margin: 0 0 8px;
  }

  .nickname {
    color: #d4b06a;
    font-weight: 800;
    margin: 0 0 14px;
  }

  .nicknames {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin: 0 0 18px;
  }

  .nicknames span {
    color: #4e5661;
    font-size: 14px;
    line-height: 1.5;
    text-align: left;
  }

  .details {
    display: grid;
    gap: 10px;
    margin-bottom: 20px;
  }

  .details p {
    display: flex;
    justify-content: space-between;
    gap: 18px;
    border-bottom: 1px solid #e8e3d8;
    padding-bottom: 8px;
    margin: 0;
    font-size: 14px;
  }

  strong {
    color: #173a5e;
  }

  span {
    text-align: right;
  }

  .engine {
    background: #ffffff;
    border: 1px solid #eee8dc;
    padding: 18px;
    margin-bottom: 18px;
  }

  .engine-topline {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 12px;
  }

  .engine-topline span {
    color: #d4b06a;
    font-weight: 900;
  }

  .score-bar {
    height: 8px;
    background: #eee8dc;
    overflow: hidden;
    margin-bottom: 14px;
  }

  .score-bar div {
    height: 100%;
    background: #d4b06a;
  }

  .engine-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 10px;
  }

  .engine-grid div {
    background: #faf9f7;
    border: 1px solid #eee8dc;
    padding: 12px 8px;
    text-align: center;
  }

  .engine-grid strong {
    display: block;
    font-size: 20px;
    margin-bottom: 5px;
  }

  .engine-grid span {
    display: block;
    text-align: center;
    color: #777;
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 1.1px;
    text-transform: uppercase;
  }

  .msrp,
  .view {
    background: #ffffff;
    border: 1px solid #eee8dc;
    padding: 18px;
    margin-bottom: 18px;
  }

  .msrp p,
  .view p {
    color: #4e5661;
    font-size: 14px;
    line-height: 1.6;
    margin-bottom: 0;
  }

  .button {
    display: block;
    text-align: center;
    background: #173a5e;
    color: white;
    padding: 14px;
    text-decoration: none;
    border-radius: 6px;
    font-weight: 700;
    margin-top: auto;
  }

  .button:hover {
    background: #0f2a45;
  }
</style>