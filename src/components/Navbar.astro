---
const brands = [
  "Rolex",
  "Patek Philippe",
  "Audemars Piguet",
  "Richard Mille",
  "Vacheron Constantin",
  "F.P. Journe",
  "Cartier",
  "Omega",
  "Tudor",
  "Panerai",
  "Breitling",
  "IWC",
];
---

<header class="navbar">
  <a href="/" class="brand-logo">
  <img src="/images/quest-luxo-logo.png" alt="Quest Luxo" class="logo" />
</a>

  <nav>
    <a href="/brands">Collections</a>
    <a href="/private-sourcing">Private Sourcing</a>
    <a href="/services">Services</a>
    <a href="/market-insights">Market Insights</a>
    <a href="/contact">Contact</a>
  </nav>
</header>

<style>
  .navbar {
    padding: 24px 60px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: #ffffff;
    border-bottom: 1px solid #ececec;
  }.brand-logo {
  display: flex;
  align-items: center;
}

.logo {
  height: 60px;
  width: auto;
  display: block;
}

  .brand {
    font-family: Georgia, serif;
    font-size: 28px;
    color: #173a5e;
    font-weight: 700;
    text-decoration: none;
  }

  nav {
    display: flex;
    gap: 28px;
  }

  nav a {
    color: #1f1f1f;
    text-decoration: none;
    font-size: 15px;
  }

  nav a:hover {
    color: #d4b06a;
  }

  @media (max-width: 800px) {
    .navbar {
      padding: 22px;
      flex-direction: column;
      gap: 18px;
    }

    nav {
      flex-wrap: wrap;
      justify-content: center;
      gap: 16px;
    }
  }
</style>