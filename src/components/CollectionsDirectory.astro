---
import { brands } from "../data/brands";
---

<section class="collections">
  <p class="eyebrow">CURATED COLLECTIONS</p>

  <h2>Explore the World’s Most Desired Watch Houses</h2>

  <div class="grid">
    {brands.map((brand) => (
      <a href={`/collections/${brand.slug}`} class="card">
        <span>{brand.name}</span>
        <p>{brand.tagline}</p>
        <small>Founded {brand.founded} · {brand.models} collections →</small>
      </a>
    ))}
  </div>
</section>

<style>
  .collections {
    padding: 120px 60px;
    background: #ffffff;
    text-align: center;
  }

  .eyebrow {
    color: #d4b06a;
    letter-spacing: 4px;
    font-size: 13px;
    font-weight: 700;
    margin-bottom: 20px;
  }

  h2 {
    color: #173a5e;
    font-size: 44px;
    max-width: 780px;
    margin: 0 auto 55px;
    line-height: 1.2;
  }

  .grid {
    max-width: 1180px;
    margin: auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
  }

  .card {
    padding: 34px 24px;
    border: 1px solid #e8e3d8;
    background: #faf9f7;
    color: #173a5e;
    text-decoration: none;
    transition: 0.2s ease;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .card span {
    font-size: 21px;
    font-weight: 700;
  }

  .card p {
    margin: 0;
    color: #555;
    font-size: 15px;
  }

  .card small {
    color: #6c6c6c;
    font-size: 14px;
  }

  .card:hover {
    border-color: #d4b06a;
    transform: translateY(-3px);
  }

  @media (max-width: 800px) {
    .collections {
      padding: 80px 22px;
    }

    .grid {
      grid-template-columns: 1fr;
    }

    h2 {
      font-size: 34px;
    }
  }
</style>