---
import type { RankedLuxuryAsset } from "../lib/intelligence/questLuxoRankings";

interface Props {
  title: string;
  subtitle: string;
  items: RankedLuxuryAsset<any>[];
  scoreLabel?: string;
}

const { title, subtitle, items, scoreLabel = "Score" } = Astro.props;
---

<section class="leaderboard">
  <div class="leaderboard-heading">
    <p class="eyebrow">QUEST LUXO RANKINGS</p>
    <h2>{title}</h2>
    <p>{subtitle}</p>
  </div>

  <div class="rankings">
    {items.map((item) => (
      <a
        class="ranking-card"
        href={`/collections/rolex/submariner/${item.asset.reference.toLowerCase()}`}
      >
        <div class="rank">#{item.rank}</div>

        <div class="asset">
          <strong>Ref. {item.asset.reference}</strong>
          <span>{item.asset.marketPosition}</span>
        </div>

        <div class="score">
          <strong>{item.overallScore}</strong>
          <span>{scoreLabel}</span>
        </div>

        <div class="grade">
          <strong>{item.grade}</strong>
          <span>Grade</span>
        </div>
      </a>
    ))}
  </div>
</section>

<style>
  .leaderboard {
    max-width: 1180px;
    margin: 90px auto;
    padding: 0 30px;
  }

  .leaderboard-heading {
    text-align: center;
    max-width: 820px;
    margin: 0 auto 46px;
  }

  .eyebrow {
    color: #d4b06a;
    letter-spacing: 4px;
    font-size: 12px;
    font-weight: 800;
    text-transform: uppercase;
    margin-bottom: 18px;
  }

  h2 {
    color: #173a5e;
    font-size: clamp(34px, 5vw, 46px);
    line-height: 1.1;
    margin: 0 0 18px;
  }

  .leaderboard-heading p {
    color: #4e5661;
    line-height: 1.75;
    font-size: 17px;
    margin: 0;
  }

  .rankings {
    display: grid;
    gap: 14px;
  }

  .ranking-card {
    display: grid;
    grid-template-columns: 80px 1fr 110px 90px;
    gap: 20px;
    align-items: center;
    background: #faf9f7;
    border: 1px solid #e8e3d8;
    color: inherit;
    text-decoration: none;
    padding: 22px 24px;
  }

  .ranking-card:hover {
    border-color: #d4b06a;
    background: #ffffff;
  }

  .rank {
    color: #d4b06a;
    font-size: 30px;
    font-weight: 900;
  }

  .asset strong,
  .score strong,
  .grade strong {
    display: block;
    color: #173a5e;
  }

  .asset strong {
    font-size: 22px;
    margin-bottom: 6px;
  }

  .asset span,
  .score span,
  .grade span {
    display: block;
    color: #6d7480;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 1.5px;
    text-transform: uppercase;
  }

  .score,
  .grade {
    text-align: center;
  }

  .score strong,
  .grade strong {
    font-size: 28px;
  }

  @media (max-width: 800px) {
    .ranking-card {
      grid-template-columns: 1fr;
      text-align: left;
    }

    .score,
    .grade {
      text-align: left;
    }
  }
</style>