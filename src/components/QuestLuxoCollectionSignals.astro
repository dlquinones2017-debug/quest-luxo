---
interface Signal {
  label: string;
  score: number;
}

interface Props {
  eyebrow?: string;
  title: string;
  description: string;
  signals: Signal[];
}

const {
  eyebrow = "COLLECTION SIGNALS",
  title,
  description,
  signals,
} = Astro.props;

const renderScore = (score: number) => `${score}/5`;
---

<section class="collection-intelligence">
  <div class="heading">
    <p class="eyebrow">{eyebrow}</p>
    <h2>{title}</h2>
    <p>{description}</p>
  </div>

  <div class="signal-grid">
    {signals.map((signal) => (
      <article>
        <div class="signal-topline">
          <strong>{signal.label}</strong>
          <span>{renderScore(signal.score)}</span>
        </div>

        <div class="bar">
          <div style={`width: ${(signal.score / 5) * 100}%`}></div>
        </div>
      </article>
    ))}
  </div>
</section>

<style>
  .collection-intelligence {
    background: #faf9f7;
    border-top: 1px solid #e8e3d8;
    border-bottom: 1px solid #e8e3d8;
    padding: 90px 30px;
  }

  .heading {
    text-align: center;
    margin: 0 auto 55px;
    max-width: 820px;
  }

  .eyebrow {
    color: #d4b06a;
    letter-spacing: 4px;
    font-size: 12px;
    font-weight: 800;
    margin-bottom: 20px;
    text-transform: uppercase;
  }

  h2 {
    color: #173a5e;
    font-size: clamp(34px, 5vw, 46px);
    line-height: 1.1;
    margin: 0 0 18px;
  }

  .heading p {
    color: #4e5661;
    line-height: 1.75;
    font-size: 17px;
    margin: 0 auto;
  }

  .signal-grid {
    max-width: 980px;
    margin: auto;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 18px;
  }

  .signal-grid article {
    background: #ffffff;
    border: 1px solid #e8e3d8;
    padding: 24px;
  }

  .signal-topline {
    display: flex;
    justify-content: space-between;
    gap: 18px;
    margin-bottom: 14px;
  }

  .signal-topline strong {
    color: #173a5e;
  }

  .signal-topline span {
    color: #d4b06a;
    font-weight: 800;
  }

  .bar {
    height: 8px;
    background: #eee8dc;
    overflow: hidden;
  }

  .bar div {
    height: 100%;
    background: #d4b06a;
  }

  @media (max-width: 900px) {
    .signal-grid {
      grid-template-columns: 1fr;
    }
  }
</style>