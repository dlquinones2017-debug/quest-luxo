---
interface Props {
  collectorDemand: number;
  liquidity: number;
  wearability: number;
  collectability: number;
  allocationDifficulty: number;
  versatility: number;

  summary: string;
}

const {
  collectorDemand,
  liquidity,
  wearability,
  collectability,
  allocationDifficulty,
  versatility,
  summary,
} = Astro.props;

const stars = (rating: number) =>
  "★".repeat(rating) + "☆".repeat(5 - rating);
---

<section class="panel">
  <div class="header">
    <p class="eyebrow">QUEST LUXO INTELLIGENCE</p>
    <h2>Reference Assessment</h2>
  </div>

  <div class="grid">

    <div class="metric">
      <span>Collector Demand</span>
      <strong>{stars(collectorDemand)}</strong>
    </div>

    <div class="metric">
      <span>Liquidity</span>
      <strong>{stars(liquidity)}</strong>
    </div>

    <div class="metric">
      <span>Daily Wearability</span>
      <strong>{stars(wearability)}</strong>
    </div>

    <div class="metric">
      <span>Long-Term Collectability</span>
      <strong>{stars(collectability)}</strong>
    </div>

    <div class="metric">
      <span>Allocation Difficulty</span>
      <strong>{stars(allocationDifficulty)}</strong>
    </div>

    <div class="metric">
      <span>Versatility</span>
      <strong>{stars(versatility)}</strong>
    </div>

  </div>

  <div class="summary">
    <h3>Quest Luxo Summary</h3>

    <p>{summary}</p>
  </div>

</section>

<style>
.panel{
    max-width:1100px;
    margin:90px auto;
    padding:40px;
    background:#faf9f7;
    border:1px solid #e8e3d8;
}

.header{
    text-align:center;
    margin-bottom:40px;
}

.eyebrow{
    color:#d4b06a;
    letter-spacing:4px;
    font-size:13px;
    font-weight:700;
}

.header h2{
    color:#173a5e;
    font-size:42px;
    margin-top:12px;
}

.grid{
    display:grid;
    grid-template-columns:repeat(2,1fr);
    gap:18px;
}

.metric{
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:18px;
    background:white;
    border:1px solid #ece7dc;
}

.metric span{
    color:#444;
}

.metric strong{
    color:#173a5e;
    font-size:22px;
}

.summary{
    margin-top:42px;
    background:white;
    border:1px solid #ece7dc;
    padding:28px;
}

.summary h3{
    color:#173a5e;
    margin-top:0;
}

.summary p{
    color:#444;
    line-height:1.8;
    font-size:18px;
}

@media(max-width:900px){

.grid{
grid-template-columns:1fr;
}

.panel{
margin:60px 20px;
padding:25px;
}

}
</style>