---
import {
  buildQuestLuxoIntelligence,
  type IntelligenceMetrics,
} from "../lib/intelligence/questLuxoIntelligence";

interface Props {
  intelligence: IntelligenceMetrics;
}

const { intelligence } = Astro.props;

const profile = buildQuestLuxoIntelligence(intelligence);

const scoreItems = [
  { label: "Market Strength", value: profile.marketStrength },
  { label: "Investment Potential", value: profile.investmentPotential },
  { label: "Rarity Score", value: profile.rarityScore },
  { label: "Confidence", value: profile.confidence },
];
---

<section class="scorecard">
  <div class="scorecard-header">
    <p class="eyebrow">QUEST LUXO INTELLIGENCE ENGINE</p>
    <h2>Asset Intelligence Score</h2>
    <p>
      Quest Luxo converts raw luxury asset signals into a structured intelligence
      profile across demand, liquidity, collectability, allocation pressure, and
      long-term market strength.
    </p>
  </div>

  <div class="scorecard-grid">
    <div class="overall">
      <span>Overall Score</span>
      <strong>{profile.overallScore}</strong>
      <small>Quest Luxo Grade: {profile.grade}</small>
    </div>

    <div class="metrics">
      {scoreItems.map((item) => (
        <article>
          <div class="metric-topline">
            <strong>{item.label}</strong>
            <span>{item.value}/100</span>
          </div>

          <div class="bar">
            <div style={`width: ${item.value}%`}></div>
          </div>
        </article>
      ))}
    </div>
  </div>

  {profile.strengths.length > 0 && (
    <div class="strengths">
      <h3>Primary Strengths</h3>

      <div class="strength-grid">
        {profile.strengths.map((strength) => (
          <span>{strength}</span>
        ))}
      </div>
    </div>
  )}
</section>

<style>
  .scorecard {
    max-width: 1180px;
    margin: 90px auto;
    padding: 0 30px;
  }

  .scorecard-header {
    text-align: center;
    max-width: 820px;
    margin: 0 auto 46px;
  }

  .eyebrow {
    color: #d4b06a;
    letter-spacing: 4px;
    font-size: 12px;
    font-weight: 800;
    text-transform: uppercase;
    margin-bottom: 18px;
  }

  h2 {
    color: #173a5e;
    font-size: clamp(34px, 5vw, 46px);
    line-height: 1.1;
    margin: 0 0 18px;
  }

  .scorecard-header p {
    color: #4e5661;
    line-height: 1.75;
    font-size: 17px;
    margin: 0;
  }

  .scorecard-grid {
    display: grid;
    grid-template-columns: 0.8fr 1.2fr;
    gap: 24px;
  }

  .overall {
    background:
      linear-gradient(rgba(23, 58, 94, 0.94), rgba(23, 58, 94, 0.94)),
      radial-gradient(circle at top, rgba(212, 176, 106, 0.35), transparent 45%);
    color: #ffffff;
    padding: 42px 32px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 330px;
  }

  .overall span {
    color: #d4b06a;
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 2.5px;
    text-transform: uppercase;
  }

  .overall strong {
    font-size: clamp(76px, 12vw, 128px);
    line-height: 0.95;
    margin: 18px 0;
  }

  .overall small {
    color: #f7ecd3;
    font-size: 16px;
    font-weight: 800;
    letter-spacing: 1.8px;
    text-transform: uppercase;
  }

  .metrics {
    display: grid;
    gap: 16px;
  }

  .metrics article {
    background: #faf9f7;
    border: 1px solid #e8e3d8;
    padding: 24px;
  }

  .metric-topline {
    display: flex;
    justify-content: space-between;
    gap: 18px;
    margin-bottom: 14px;
  }

  .metric-topline strong {
    color: #173a5e;
  }

  .metric-topline span {
    color: #d4b06a;
    font-weight: 800;
  }

  .bar {
    height: 9px;
    background: #eee8dc;
    overflow: hidden;
  }

  .bar div {
    height: 100%;
    background: #d4b06a;
  }

  .strengths {
    margin-top: 24px;
    background: #ffffff;
    border: 1px solid #e8e3d8;
    padding: 30px;
  }

  .strengths h3 {
    color: #173a5e;
    margin: 0 0 20px;
    font-size: 26px;
  }

  .strength-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .strength-grid span {
    background: #faf9f7;
    border: 1px solid #e8e3d8;
    color: #173a5e;
    padding: 11px 14px;
    border-radius: 999px;
    font-size: 13px;
    font-weight: 800;
  }

  @media (max-width: 900px) {
    .scorecard-grid {
      grid-template-columns: 1fr;
    }

    .overall {
      min-height: auto;
    }
  }
</style>