---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import QuestLuxoCollectionHero from "../../../../components/QuestLuxoCollectionHero.astro";
import QuestLuxoCollectionSignals from "../../../../components/QuestLuxoCollectionSignals.astro";
import QuestLuxoIntelligence from "../../../../components/QuestLuxoIntelligence.astro";
import QuestLuxoDirectoryToolbar from "../../../../components/QuestLuxoDirectoryToolbar.astro";
import QuestLuxoReferenceGrid from "../../../../components/QuestLuxoReferenceGrid.astro";
import PrivateSourcingCTA from "../../../../components/PrivateSourcingCTA.astro";
import { daytonaAssets } from "../../../../data/assets/rolex-daytona";
import {
  buildCollectionSignals,
  buildCollectionSummary,
} from "../../../../lib/intelligence/collectionFactory";

const daytonaCollection = {
  brand: "Rolex",
  collection: "Daytona",
  assets: daytonaAssets,
};

const summary = buildCollectionSummary(daytonaCollection);
const collectionSignals = buildCollectionSignals(daytonaCollection);
---

<BaseLayout title="Rolex Daytona | Quest Luxo">
  <QuestLuxoCollectionHero
    eyebrow="ROLEX COLLECTION INTELLIGENCE"
    title="Daytona"
    description="The Rolex Cosmograph Daytona is one of the most important modern luxury chronographs, combining motorsport heritage, extreme allocation pressure, and deep collector demand across steel, precious-metal, Oysterflex, and platinum references."
    stats={[
      {
        value: summary.totalAssets,
        label: "Tracked References",
      },
      {
        value: summary.currentReferences,
        label: "Current Production",
      },
      {
        value: summary.discontinuedReferences,
        label: "Discontinued Icons",
      },
      {
        value: summary.peakDemandReferences,
        label: "Peak Demand Signals",
      },
    ]}
  />

  <QuestLuxoIntelligence
    title="Daytona Market Position"
    paragraphs={[
      "The Daytona sits at the center of modern Rolex collecting, supported by iconic design, strong secondary-market liquidity, and persistent allocation pressure across steel and select precious-metal configurations.",
      "Quest Luxo evaluates Daytona references by generation, bezel type, dial configuration, production status, material, collector recognition, and long-term market desirability.",
    ]}
  />

  <QuestLuxoCollectionSignals
    title="Quest Luxo Daytona Intelligence"
    description="These scores summarize the current Daytona reference set inside Quest Luxo's Rolex intelligence directory."
    signals={collectionSignals}
  />

  <section class="assets">
    <div class="heading">
      <p class="eyebrow">ASSET DIRECTORY</p>
      <h2>Daytona Reference Profiles</h2>
      <p>
        Search, filter, and sort Daytona references by generation, nickname,
        material, production status, and Quest Luxo intelligence score.
      </p>
    </div>

    <QuestLuxoDirectoryToolbar totalCount={daytonaAssets.length} />

    <QuestLuxoReferenceGrid
      assets={daytonaAssets}
      basePath="/collections/rolex/daytona"
      emptyTitle="No Daytona references match this search."
      emptyText="Try clearing your search, selecting All, or searching by reference, nickname, material, bezel, or market position."
    />
  </section>

  <PrivateSourcingCTA
    title="Request Private Daytona Sourcing"
    text="Quest Luxo coordinates discreet sourcing for clients seeking current, discontinued, and collector-grade Rolex Daytona references."
  />
</BaseLayout>

<style>
  .assets {
    background: #ffffff;
    padding: 90px 60px 120px;
  }

  .heading {
    text-align: center;
    margin: 0 auto 55px;
    max-width: 820px;
  }

  .eyebrow {
    color: #d4b06a;
    letter-spacing: 4px;
    font-size: 12px;
    font-weight: 800;
    margin-bottom: 20px;
    text-transform: uppercase;
  }

  .heading h2 {
    color: #173a5e;
    font-size: clamp(34px, 5vw, 46px);
    line-height: 1.1;
    margin: 0 0 18px;
  }

  .heading p {
    color: #4e5661;
    line-height: 1.75;
    font-size: 17px;
    margin: 0 auto;
  }

  @media (max-width: 900px) {
    .assets {
      padding: 70px 22px;
    }
  }
</style>