---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import QuestLuxoIntelligence from "../../../../components/QuestLuxoIntelligence.astro";
import PrivateSourcingCTA from "../../../../components/PrivateSourcingCTA.astro";
import ReferenceCard from "../../../../components/ReferenceCard.astro";
import { yachtMasterAssets } from "../../../../data/assets/rolex-yacht-master";
---

<BaseLayout title="Rolex Yacht-Master | Quest Luxo">
  <section class="hero">
    <p class="eyebrow">ROLEX COLLECTION</p>
    <h1>Yacht-Master</h1>
    <p>
      The Rolex Yacht-Master blends nautical sport design with luxury finishing,
      spanning Rolesium, Everose Rolesor, precious metal, and Oysterflex references.
    </p>
  </section>

  <QuestLuxoIntelligence
    title="Yacht-Master Market Position"
    paragraphs={[
      "The Yacht-Master occupies a refined position within Rolex’s professional collection, appealing to clients who want sport utility with a softer luxury profile than the Submariner or GMT-Master II.",
      "Quest Luxo evaluates Yacht-Master acquisitions by reference, case size, material, bezel, bracelet, condition, set completeness, and current sourcing availability."
    ]}
  />

  <section class="assets">
    <div class="heading">
      <p class="eyebrow">ASSET DIRECTORY</p>
      <h2>Yacht-Master Reference Profiles</h2>
    </div>

    <div class="grid">
      {yachtMasterAssets.map((asset) => (
        <ReferenceCard
          asset={asset}
          href={`/collections/rolex/yacht-master/${asset.reference.toLowerCase()}`}
        />
      ))}
    </div>
  </section>

  <PrivateSourcingCTA
    title="Request Private Yacht-Master Sourcing"
    text="Quest Luxo coordinates discreet sourcing for clients seeking current, discontinued, and collector-grade Rolex Yacht-Master references."
  />
</BaseLayout>

<style>
  .hero {
    padding: 120px 30px 70px;
    text-align: center;
    background: #faf9f7;
  }

  .eyebrow {
    color: #d4b06a;
    letter-spacing: 4px;
    font-size: 13px;
    font-weight: 700;
    margin-bottom: 20px;
  }

  .hero h1 {
    color: #173a5e;
    font-size: 72px;
    margin-bottom: 24px;
  }

  .hero p {
    max-width: 820px;
    margin: auto;
    font-size: 22px;
    line-height: 1.8;
    color: #1f1f1f;
  }

  .assets {
    background: #ffffff;
    padding: 90px 60px 120px;
  }

  .heading {
    text-align: center;
    margin-bottom: 55px;
  }

  .heading h2 {
    color: #173a5e;
    font-size: 44px;
    margin: 0;
  }

  .grid {
    max-width: 1180px;
    margin: auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  @media (max-width: 900px) {
    .grid {
      grid-template-columns: 1fr;
    }

    .hero h1 {
      font-size: 46px;
    }

    .assets {
      padding: 70px 22px;
    }
  }
</style>