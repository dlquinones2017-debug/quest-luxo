---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import QuestLuxoReferenceGrid from "../../../../components/QuestLuxoReferenceGrid.astro";
import PrivateSourcingCTA from "../../../../components/PrivateSourcingCTA.astro";

import { gmtMasterIIAssets } from "../../../../data/assets/rolex-gmt-master-ii";

const assets = gmtMasterIIAssets;

const currentCount = assets.filter((asset) => asset.productionStatus === "Current").length;
const discontinuedCount = assets.filter((asset) => asset.productionStatus === "Discontinued").length;
const peakDemandCount = assets.filter(
  (asset) => asset.intelligence.collectorDemand >= 5
).length;

const averageLiquidity =
  assets.reduce((total, asset) => total + asset.intelligence.liquidity, 0) /
  assets.length;
---

<BaseLayout title="Rolex GMT-Master II | Quest Luxo">
  <main class="collection-page">
    <section class="hero">
      <p class="eyebrow">Rolex Factory Mode</p>
      <h1>Rolex GMT-Master II</h1>
      <p>
        Dual-time Rolex sports references ranked by collector demand, liquidity,
        allocation difficulty, market recognition, and private sourcing strength.
      </p>
    </section>

    <section class="signals">
      <div>
        <strong>{assets.length}</strong>
        <span>Tracked References</span>
      </div>

      <div>
        <strong>{currentCount}</strong>
        <span>Current Production</span>
      </div>

      <div>
        <strong>{discontinuedCount}</strong>
        <span>Discontinued</span>
      </div>

      <div>
        <strong>{peakDemandCount}</strong>
        <span>Peak Demand</span>
      </div>

      <div>
        <strong>{averageLiquidity.toFixed(1)}/5</strong>
        <span>Avg. Liquidity</span>
      </div>
    </section>

    <section class="directory">
      <div class="section-header">
        <p class="eyebrow">Reference Directory</p>
        <h2>GMT-Master II Asset Intelligence</h2>
        <p>
          Explore core steel, discontinued ceramic, two-tone, and precious-metal
          GMT-Master II references built for the Quest Luxo luxury asset platform.
        </p>
      </div>

      <QuestLuxoReferenceGrid
        assets={assets}
        basePath="/collections/rolex/gmt-master-ii"
      />
    </section>

    <PrivateSourcingCTA
      eyebrow="Private Sourcing"
      title="Source a Rolex GMT-Master II"
      body="Quest Luxo helps collectors evaluate, source, and position high-demand Rolex GMT-Master II references with private-market intelligence."
    />
  </main>
</BaseLayout>

<style>
  .collection-page {
    background:
      radial-gradient(circle at top left, rgba(184, 164, 111, 0.12), transparent 34rem),
      #050505;
    color: #f6efe4;
    min-height: 100vh;
  }

  .hero,
  .signals,
  .directory {
    max-width: 1180px;
    margin: 0 auto;
    padding: 56px 24px;
  }

  .hero {
    padding-top: 84px;
  }

  .eyebrow {
    color: #b8a46f;
    font-size: 0.75rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    margin-bottom: 16px;
  }

  h1 {
    font-size: clamp(3rem, 8vw, 6rem);
    line-height: 0.92;
    margin: 0 0 22px;
  }

  h2 {
    font-size: clamp(2rem, 4vw, 3.5rem);
    line-height: 1;
    margin: 0 0 18px;
  }

  .hero p,
  .section-header p {
    max-width: 820px;
    color: #cfc7b8;
    font-size: 1.08rem;
    line-height: 1.7;
  }

  .signals {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 16px;
    padding-top: 16px;
  }

  .signals div {
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 22px;
    background: rgba(255, 255, 255, 0.035);
    padding: 22px;
  }

  .signals strong {
    display: block;
    color: #f6efe4;
    font-size: 2rem;
    margin-bottom: 8px;
  }

  .signals span {
    color: #9f9788;
    font-size: 0.82rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .section-header {
    margin-bottom: 28px;
  }

  @media (max-width: 960px) {
    .signals {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .signals {
      grid-template-columns: 1fr;
    }
  }
</style>