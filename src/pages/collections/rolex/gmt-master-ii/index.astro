---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import QuestLuxoIntelligence from "../../../../components/QuestLuxoIntelligence.astro";
import PrivateSourcingCTA from "../../../../components/PrivateSourcingCTA.astro";
import { gmtAssets } from "../../../../data/assets/rolex-gmt-master-ii";

const formatUSD = (value: number | null) => {
  if (!value) return "Historical MSRP research pending";

  return new Intl.NumberFormat("en-US", {
    style: "currency",
    currency: "USD",
    maximumFractionDigits: 0,
  }).format(value);
};
---

<BaseLayout title="Rolex GMT-Master II | Quest Luxo">
  <section class="hero">
    <p class="eyebrow">ROLEX COLLECTION</p>
    <h1>GMT-Master II</h1>
    <p>
      The Rolex GMT-Master II remains one of the most liquid and recognizable
      travel watches in the luxury market, with strong demand across current,
      discontinued, and collector-driven references.
    </p>
  </section>

  <QuestLuxoIntelligence
    title="GMT-Master II Market Position"
    paragraphs={[
      "The GMT-Master II remains one of Rolex’s strongest modern sports watch categories due to broad recognition, high liquidity, and persistent collector demand across steel, two-tone, precious-metal, and discontinued references.",
      "Quest Luxo evaluates each acquisition by reference, configuration, production status, bracelet, condition, set completeness, and current sourcing availability."
    ]}
  />

  <section class="assets">
    <div class="heading">
      <p class="eyebrow">ASSET DIRECTORY</p>
      <h2>GMT-Master II Reference Profiles</h2>
    </div>

    <div class="grid">
      {gmtAssets.map((asset) => (
        <article class="card">
          <div class="image-placeholder">Image Pending</div>

          <p class="model">Rolex {asset.model}</p>
          <h3>Ref. {asset.reference}</h3>

          <div class="nicknames">
            {asset.configurations.map((config) => (
              <span>{config.nickname} · {config.bracelet}</span>
            ))}
          </div>

          <div class="details">
            <p><strong>Material</strong><span>{asset.material}</span></p>
            <p><strong>Bezel</strong><span>{asset.bezel}</span></p>
            <p><strong>Production</strong><span>{asset.productionStatus}</span></p>
            <p><strong>Market Position</strong><span>{asset.marketPosition}</span></p>
            <p><strong>Liquidity</strong><span>{asset.liquidity}</span></p>
            <p><strong>Allocation Difficulty</strong><span>{asset.allocationDifficulty}</span></p>
          </div>

          <div class="msrp">
            <strong>Original MSRP</strong>
            {asset.configurations.map((config) => (
              <p>{config.bracelet}: {formatUSD(config.originalMSRP)}</p>
            ))}
          </div>

          <div class="view">
            <strong>Quest Luxo View</strong>
            <p>{asset.questLuxoView}</p>
          </div>

<a href={`/collections/rolex/gmt-master-ii/${asset.reference.toLowerCase()}`} class="button">
  View Asset Profile
</a>        </article>
      ))}
    </div>
  </section>
  <PrivateSourcingCTA />
</BaseLayout>

<style>
  .hero {
    padding: 120px 30px 70px;
    text-align: center;
    background: #faf9f7;
  }

  .eyebrow {
    color: #d4b06a;
    letter-spacing: 4px;
    font-size: 13px;
    font-weight: 700;
    margin-bottom: 20px;
  }

  .hero h1 {
    color: #173a5e;
    font-size: 72px;
    margin-bottom: 24px;
  }

  .hero p {
    max-width: 820px;
    margin: auto;
    font-size: 22px;
    line-height: 1.8;
    color: #1f1f1f;
  }

  .assets {
    background: #ffffff;
    padding: 90px 60px 120px;
  }

  .heading {
    text-align: center;
    margin-bottom: 55px;
  }

  .heading h2 {
    color: #173a5e;
    font-size: 44px;
    margin: 0;
  }

  .grid {
    max-width: 1180px;
    margin: auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .card {
    border: 1px solid #e8e3d8;
    background: #faf9f7;
    padding: 24px;
  }

  .image-placeholder {
    height: 220px;
    background: white;
    border: 1px solid #eee8dc;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #777;
    margin-bottom: 24px;
  }

  .model {
    color: #777;
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin: 0 0 8px;
  }

  h3 {
    color: #173a5e;
    font-size: 28px;
    margin: 0 0 16px;
  }

  .nicknames {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 22px;
  }

  .nicknames span {
    color: #d4b06a;
    font-weight: 700;
  }

  .details {
    display: grid;
    gap: 10px;
    margin-bottom: 22px;
  }

  .details p {
    display: flex;
    justify-content: space-between;
    gap: 20px;
    border-bottom: 1px solid #e8e3d8;
    padding-bottom: 10px;
    margin: 0;
    color: #444;
    font-size: 14px;
  }

  .details strong {
    color: #173a5e;
  }

  .details span {
    text-align: right;
  }

  .msrp,
  .view {
    background: white;
    border: 1px solid #eee8dc;
    padding: 18px;
    margin-bottom: 18px;
  }

  .msrp strong,
  .view strong {
    color: #173a5e;
  }

  .msrp p,
  .view p {
    color: #444;
    line-height: 1.6;
    margin: 8px 0 0;
  }

  .button {
    display: block;
    text-align: center;
    background: #173a5e;
    color: white;
    padding: 14px 18px;
    text-decoration: none;
    border-radius: 6px;
    font-weight: 700;
  }

  @media (max-width: 900px) {
    .grid {
      grid-template-columns: 1fr;
    }

    .hero h1 {
      font-size: 46px;
    }

    .assets {
      padding: 70px 22px;
    }
  }
</style>