---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { rolex } from "../../data/rolex/index";
---

<BaseLayout title="Rolex | Quest Luxo">
  <section class="hero">
    <p class="eyebrow">COLLECTIONS</p>
    <h1>{rolex.name}</h1>
    <p>{rolex.description}</p>
  </section>

  <section class="grid">
    {rolex.collections.map((collection) => (
      <a href={`/collections/rolex/${collection.slug}`} class="card">
        <h2>{collection.name}</h2>
        <p>{collection.description}</p>
        <small>Private sourcing available →</small>
      </a>
    ))}
  </section>
</BaseLayout>

<style>
  .hero {
    padding: 120px 30px 60px;
    text-align: center;
    background: #faf9f7;
  }

  .eyebrow {
    color: #d4b06a;
    letter-spacing: 4px;
    font-size: 13px;
    font-weight: 700;
    margin-bottom: 20px;
  }

  .hero h1 {
    color: #173a5e;
    font-size: 72px;
    margin-bottom: 24px;
  }

  .hero p {
    max-width: 760px;
    margin: auto;
    font-size: 22px;
    line-height: 1.8;
    color: #1f1f1f;
  }

  .grid {
    max-width: 1180px;
    margin: 50px auto 110px;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    padding: 0 30px;
  }

  .card {
    background: white;
    padding: 38px;
    text-decoration: none;
    color: #173a5e;
    border: 1px solid #e8e3d8;
    transition: 0.2s ease;
  }

  .card:hover {
    transform: translateY(-4px);
    border-color: #d4b06a;
  }

  .card h2 {
    margin: 0 0 14px;
    font-size: 28px;
  }

  .card p {
    color: #444;
    line-height: 1.7;
    margin-bottom: 20px;
  }

  .card small {
    color: #d4b06a;
    font-weight: 700;
  }

  @media (max-width: 900px) {
    .grid {
      grid-template-columns: 1fr;
    }

    .hero h1 {
      font-size: 46px;
    }
  }
</style>